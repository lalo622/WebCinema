@model WebCinema.Models.Movie
@{
    ViewBag.Title = "Edit";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css" />

<style>
    .main-content {
        padding: 15px;
        background-color: #f8f9fa;
    }

    .form-container {
        background: white;
        border-radius: 8px;
        box-shadow: 0 2px 6px rgba(0,0,0,0.05);
        padding: 20px;
        max-width: 900px;
        margin-right: auto;
        margin-left: 0;
    }

    .page-title {
        color: #333;
        font-size: 22px;
        font-weight: 600;
        margin-bottom: 20px;
        padding-bottom: 10px;
        border-bottom: 1px solid #eee;
    }

    .form-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
        gap: 15px;
    }

    .form-group {
        margin-bottom: 15px;
    }

        .form-group label {
            font-weight: 500;
            color: #495057;
            margin-bottom: 5px;
            font-size: 14px;
            display: block;
        }

    .form-control {
        border: 1px solid #ced4da;
        border-radius: 4px;
        padding: 8px 12px;
        font-size: 14px;
        height: 38px;
        width: 100%;
    }

    textarea.form-control {
        min-height: 100px;
        resize: vertical;
    }

    .btn-action {
        padding: 8px 16px;
        font-size: 14px;
        border-radius: 4px;
        margin-right: 10px;
    }

    .btn-save {
        background-color: #28a745;
        color: white;
        border: none;
    }

    .btn-cancel {
        background-color: #6c757d;
        color: white;
        border: none;
    }

    .file-upload {
        display: flex;
        align-items: center;
    }

        .file-upload input[type="file"] {
            display: none;
        }

    .file-upload-label {
        background-color: #f8f9fa;
        border: 1px dashed #ced4da;
        padding: 8px 12px;
        border-radius: 4px;
        cursor: pointer;
        font-size: 14px;
        display: flex;
        align-items: center;
        width: 100%;
    }

        .file-upload-label:hover {
            background-color: #e9ecef;
        }

    .file-icon {
        margin-right: 8px;
        color: #6c757d;
    }

    .required-field::after {
        content: " *";
        color: #dc3545;
    }

    .form-actions {
        margin-top: 20px;
        padding-top: 15px;
        border-top: 1px solid #eee;
        text-align: left;
    }

    @@media (max-width: 768px) {
        .form-grid {
            grid-template-columns: 1fr;
        }

        .form-container {
            padding: 15px;
        }
    }
</style>
<h2>Chỉnh sửa</h2>


<div class="main-content">
    <div class="form-container">
        <h2 class="page-title">Chỉnh sửa phim</h2>
        @using (Html.BeginForm("Edit", "Movies", FormMethod.Post, new { enctype = "multipart/form-data" }))
        {
            @Html.Partial("PVCreateEditMovies", Model)
        }
    </div>

</div>
@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
    <script>
        $(document).ready(function () {
            // Hiển thị tên file khi chọn
            $('#fileUpload').change(function () {
                var fileName = $(this).val().split('\\').pop();
                $('#fileName').text(fileName || "Chưa có tệp nào được chọn");
            });

            // Thiết lập ngày mặc định
            var today = new Date().toISOString().split('T')[0];
            $('#ReleaseDate').val(today);

            // Tự động tính ngày kết thúc (30 ngày sau)
            var endDate = new Date();
            endDate.setDate(endDate.getDate() + 30);
            var endDateStr = endDate.toISOString().split('T')[0];
            $('#EndDate').val(endDateStr);
        });
    </script>
}
