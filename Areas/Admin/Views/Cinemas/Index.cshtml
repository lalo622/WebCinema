@model IEnumerable<WebCinema.Models.Cinema>

@{
    ViewBag.Title = "Index";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<h2>Quản lý Rạp</h2>

<p>
    @Html.ActionLink("Thêm mới", "Create")
</p>
<table class="table">
    <tr>
        <th>
            Tên Rạp
        </th>
        <th>
            Địa chỉ
        </th>
        <th>
           SĐT
        </th>
        <th>
           Trạng thái hoạt động
        </th>
        <th></th>
    </tr>

@foreach (var item in Model) {
    <tr>
        <td>
            @Html.DisplayFor(modelItem => item.Name)
        </td>
        <td>
            @Html.DisplayFor(modelItem => item.Address)
        </td>
        <td>
            @Html.DisplayFor(modelItem => item.Phone)
        </td>
        <td>
            @Html.DisplayFor(modelItem => item.Status)
        </td>
        <td>
            @Html.ActionLink("Edit", "Edit", new { id=item.CinemaID }) |
            @Html.ActionLink("Details", "Details", new { id=item.CinemaID }) |
            @Html.ActionLink("Delete", "Delete", new { id=item.CinemaID })
        </td>
    </tr>
}

</table>
